{
  "name": "preh-nav",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n VITE,MAN \"vite\" \"node scripts/watch_manifest.mjs\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 5173",
    "gen:manifest": "node scripts/generate_manifest.mjs",
    "postinstall": "node scripts/generate_manifest.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": {
      "esbuild": "^0.25.0"
    }
  },
  "dependencies": {
    "express-rate-limit": "^8.3.2",
    "fuse.js": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
